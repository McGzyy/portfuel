# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# TOTP encryption (32-byte hex or any long secret)
TOTP_ENCRYPTION_KEY=change-me-totp-encryption-key-32chars-min

# Finnhub market data
FINNHUB_API_KEY=your-finnhub-api-key

# Vercel Cron
CRON_SECRET=change-me-cron-secret

# App URL (for TOTP QR labels)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UI preview: fill feeds with sample member + Fueled calls (no DB writes for demo IDs)
NEXT_PUBLIC_DEMO_MODE=false

# Pro intelligence: show paywall overlays on dashboard (founder preview). Active members still gated when true.
NEXT_PUBLIC_PRO_GATES_PREVIEW=false

# Unlock all pro intelligence without Stripe tier (dev / launch — active members already have access)
NEXT_PUBLIC_PRO_INTEL_UNLOCK=false

# Stripe (subscriptions — see docs/STRIPE.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MEMBER=price_...
STRIPE_PRICE_PRO=price_...

# Admin account (scripts/seed.mjs, set-admin-password.mjs)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password1
ADMIN_TOTP_SECRET=
# Legacy — only used if migrating old admin row by pin
ADMIN_PIN=21296
