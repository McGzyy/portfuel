# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# TOTP encryption (32-byte hex or any long secret)
TOTP_ENCRYPTION_KEY=change-me-totp-encryption-key-32chars-min

# Finnhub — quotes, news, earnings (free). Stock candles need paid tier; we fall back to Twelve Data.
FINNHUB_API_KEY=your-finnhub-api-key

# Twelve Data — free chart candles (~800 API calls/day). Sign up at https://twelvedata.com → Dashboard → API Key
TWELVEDATA_API_KEY=your-twelve-data-api-key

# Vercel Cron
CRON_SECRET=change-me-cron-secret

# App URL (for TOTP QR labels)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal bot access (Discord bot -> PortFuel API)
BOT_API_KEY=change-me-bot-api-key-long-random

# Discord bot (Phase 1) — runs on your droplet via docker-compose.discord-bot.yml (not Vercel).
# In Discord Developer Portal → Bot → enable **Message Content Intent** for DM help Q&A.
DISCORD_TOKEN=
DISCORD_GUILD_ID=1508150607285063850
DISCORD_ROLE_UNVERIFIED_ID=1510855393184714893
DISCORD_ROLE_VERIFIED_ID=1510805030666506311
DISCORD_ROLE_MEMBER_ID=1510805558569992272
DISCORD_ROLE_PRO_ID=1510805852154757190
DISCORD_CHANNEL_VERIFICATION_ID=1510828920487022652
DISCORD_CHANNEL_OFFICIAL_LINKS_ID=1510828840161771631
# #member-calls (member-published theses)
DISCORD_CHANNEL_CALLS_ID=1510841810430197991
DISCORD_CHANNEL_ANNOUNCEMENTS_ID=1510841366777823352
DISCORD_CHANNEL_GENERAL_CHAT_ID=1508150608106881026
# #fueled-calls (Fueled desk only)
DISCORD_CHANNEL_FIRE_CALLS_ID=1510860334628602027
DISCORD_CHANNEL_TARGETS_ID=1510842222143340707
DISCORD_CHANNEL_MEMBER_CHAT_ID=1510799917415923763
DISCORD_CHANNEL_PRO_MEMBER_CHAT_ID=1510799989213757460
DISCORD_CHANNEL_BOT_LOG_ID=
DISCORD_NOTIFICATIONS_ENABLED=true
DISCORD_MIN_ACCOUNT_AGE_DAYS=1
PORTFUEL_APP_URL=http://localhost:3000
DISCORD_BOT_WORKER_ID=discord-bot

# UI preview: fill feeds with sample member + Fueled calls (no DB writes for demo IDs)
NEXT_PUBLIC_DEMO_MODE=false

# Pro intelligence: show paywall overlays on dashboard (founder preview). Active members still gated when true.
NEXT_PUBLIC_PRO_GATES_PREVIEW=false

# Unlock all pro intelligence without Stripe tier (dev / launch — active members already have access)
NEXT_PUBLIC_PRO_INTEL_UNLOCK=false

# Resend (email alerts — see docs/EMAIL.md)
RESEND_API_KEY=re_...
EMAIL_FROM=PortFuel <notifications@portfuel.pro>
# Require verified email before workspace (default on when Resend is configured)
REQUIRE_EMAIL_VERIFICATION=true

# Join/profile: show annual billing toggle when Stripe annual prices are configured
NEXT_PUBLIC_ANNUAL_BILLING_ENABLED=true

# OpenAI — thesis coach, journal research, admin X ingest (see docs/AI.md)
OPENAI_API_KEY=sk-...
# Optional model override:
AI_COACH_MODEL=gpt-4o-mini

# Twilio — Pro SMS watchlist alerts (optional; see Profile → Alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Web Push (PWA watchlist alerts — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@portfuel.pro

# Stripe (subscriptions — see docs/STRIPE.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MEMBER=price_...
STRIPE_PRICE_PRO=price_...
# Optional annual subscriptions (yearly recurring prices in Stripe)
STRIPE_PRICE_MEMBER_ANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# X (Twitter) social — optional; see docs/X-SOCIAL.md
X_API_ENABLED=false
X_API_DRY_RUN=true
X_API_BEARER_TOKEN=
X_POST_FUELED=true
X_POST_LEADERBOARD=true
# Keep false — X only auto-posts Fueled milestones (+10/+25/target), not new calls.
X_AUTOPOST_FUELED_ON_PUBLISH=false
# Keep false until you dry-run approve milestone copy in Admin → Social
X_AUTOPOST_MILESTONES=false
# Member win spotlights (opt-in only; default off until you enable)
X_POST_MEMBER_WINS=false
# Quote-tweet updates when a spotlighted call hits +25% or target (requires original member_win post)
X_POST_MEMBER_WIN_UPDATES=false
# Monday-style recap with composite image (top 3 member calls, last 7 days)
X_POST_WEEKLY_DIGEST=false
# Optional comma-separated symbols excluded from member spotlight (e.g. GME,AMC)
X_MEMBER_WIN_SYMBOL_BLOCKLIST=
# Eligibility: +20% after 48h, OR +30% after 36h, then 48h review window before X post
X_MEMBER_WIN_MIN_RETURN_PCT=20
X_MEMBER_WIN_MIN_AGE_HOURS=48
X_MEMBER_WIN_FAST_TRACK_RETURN_PCT=30
X_MEMBER_WIN_FAST_TRACK_MIN_AGE_HOURS=36
X_MEMBER_WIN_SUSTAIN_HOURS=48

# Admin account (scripts/seed.mjs, set-admin-password.mjs)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password1
# Personal member account username for admin identity switcher (optional)
ADMIN_PERSONAL_USERNAME=
ADMIN_TOTP_SECRET=
# Optional — extra inboxes for admin alerts (comma-separated). Admin user emails are included automatically.
ADMIN_NOTIFY_EMAIL=hello@portfuel.pro
# Legacy — only used if migrating old admin row by pin
ADMIN_PIN=21296
