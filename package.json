{
  "name": "portfuel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test tests/*.test.mjs && npx tsx --test tests/call-credit.test.mts && npm run test:social",
    "test:social": "npx tsx --test tests/social-smoke.test.mts",
    "smoke:social": "npx tsx scripts/smoke-social.mts",
    "migrations:list": "node scripts/list-migrations.mjs",
    "verify:launch": "node --env-file=.env.local scripts/verify-launch.mjs",
    "brand-assets": "node scripts/optimize-brand-assets.mjs",
    "marketing:export": "npx tsx scripts/export-marketing-assets.mjs",
    "social-chart:preview": "npx tsx scripts/preview-social-chart.ts",
    "clear-auth-attempts": "node --env-file=.env.local scripts/clear-auth-attempts.mjs",
    "admin:sync": "node --env-file=.env.local scripts/set-admin-password.mjs && node --env-file=.env.local scripts/reset-admin-totp.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@fontsource/inter": "^4.5.15",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.106.1",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dejavu-fonts-ttf": "^2.37.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "inter-ui": "^4.1.1",
    "jose": "^6.2.3",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
